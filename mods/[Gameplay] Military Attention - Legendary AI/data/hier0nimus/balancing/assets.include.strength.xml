        <ModOp Type="merge" GUID="167" Path="/Values/Interaction/DropReactionConfig">
            <DropReaction>
                <PositiveEffect>
                    <CoolDownAfterThresholdHasBeenReached>1800000</CoolDownAfterThresholdHasBeenReached>
                </PositiveEffect>
                <IncidentResolver>
                    <CoolDownAfterThresholdHasBeenReached>1800000</CoolDownAfterThresholdHasBeenReached>
